{
  // Per-tile-type strength. See World/MaterialStrengths.cs for load semantics.
  // Keys are TileType enum names (case-insensitive). MaxHP is in the same
  // TileMaxHP-multiple units as the legacy switch:
  //   Sand 0.5 — crumbles fast
  //   Dirt 1.0 — baseline (one full slash breaks it)
  //   Stone 2.0 — needs multiple slashes
  //   Foam 0.5 — cheap throwaway, also decays back to Empty after FoamLifetime

  "Stone": { "MaxHP": 2.0 },
  "Dirt":  { "MaxHP": 1.0 },
  "Sand":  { "MaxHP": 0.5 },
  "Foam":  { "MaxHP": 0.5 }
}
