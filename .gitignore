.vscode
.config
.claude

# Build output — every project's bin/obj, plus Content's intermediate obj/
**/bin/
**/obj/

# MTile.Web stages a copy of the game assets into its own wwwroot/ at build time
# so the Blazor WASM dev server can serve them. The originals live at repo root.
MTile.Web/wwwroot/game_config.json
MTile.Web/wwwroot/movement_config.json
MTile.Web/wwwroot/Levels/
MTile.Web/wwwroot/Content/

# Local sim CSVs the tests dump on run — regenerated each test run.
MTile.Tests/*.csv
